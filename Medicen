<script>
    const btnsTotal = 58;
    let cMap = {};
    for (let i=1; i<=btnsTotal; i++) cMap['btn_'+i] = 0;
    const STORE = 'medical_58_v2', RKEY = 'auto_rounds_medical_v2';

    function lCounts() { try { let s=localStorage.getItem(STORE); if(s) { let p=JSON.parse(s); for(let k in cMap) if(typeof p[k]==='number') cMap[k]=p[k]; } } catch(e){} }
    function sCounts() { try { localStorage.setItem(STORE, JSON.stringify(cMap)); } catch(e){} }
    function total() { return Object.values(cMap).reduce((a,b)=>a+b,0); }

    function refresh() {
        document.getElementById('globalCounter').innerText = total();
        for (let i=1; i<=btnsTotal; i++) {
            let cs = document.getElementById('count_'+i), b = document.getElementById('btn_'+i);
            if (cs && b) { let v = cMap['btn_'+i]||0; cs.innerText = v; v>0 ? b.classList.add('clicked') : b.classList.remove('clicked'); }
        }
    }

    function inc(id) { if(cMap.hasOwnProperty(id)) { cMap[id]++; refresh(); sCounts(); } }

    function resetAllCounters() { for (let i=1; i<=btnsTotal; i++) cMap['btn_'+i] = 0; refresh(); sCounts(); }

    function openPopupSettings() {
        let a = window.open('about:blank', '_blank');
        if(a){a.document.write(`<html><head><title>Allow Popups</title><style>body{font-family:sans-serif;background:#0b1a2e;color:#fff;text-align:center;padding:40px;line-height:1.8;}.steps{background:#1b2d4e;padding:25px;border-radius:15px;display:inline-block;text-align:left;margin:20px;}.highlight{color:#ffd166;font-weight:bold;}code{background:#000;padding:4px 10px;border-radius:6px;color:#ffd166;font-size:16px;}button{background:#6b9dff;color:#1a0b2e;border:none;padding:12px 30px;border-radius:30px;font-size:16px;cursor:pointer;margin-top:15px;font-weight:bold;}</style></head><body><h1>🔓 Allow Popups</h1><div class="steps"><p>📋 <span class="highlight">Step 1:</span> Copy URL:</p><p><code>chrome://settings/content/popups</code></p><p>📌 <span class="highlight">Step 2:</span> Open new tab (Ctrl+T)</p><p>📎 <span class="highlight">Step 3:</span> Paste & Enter</p><p>🔍 <span class="highlight">Step 4:</span> Allow this site</p><p>🔄 <span class="highlight">Step 5:</span> Come back & START</p></div><button onclick="navigator.clipboard.writeText('chrome://settings/content/popups').then(function(){}).catch(function(){})">📋 COPY SETTINGS URL</button></body></html>`);a.document.close();}
    }

    function gRounds() { try { let s=localStorage.getItem(RKEY); return s ? parseInt(s) : 3; } catch(e){ return 3; } }
    function saveRoundSetting() {
        let inp = document.getElementById('roundInput'), cf = document.getElementById('saveConfirm');
        let v = parseInt(inp.value); if(isNaN(v)||v<1) v=1; if(v>100) v=100;
        inp.value = v; localStorage.setItem(RKEY, v);
        document.getElementById('roundDisplay').innerText = v;
        cf.innerText = '✅ Saved: '+v+' round(s)'; setTimeout(()=>cf.innerText='',2000);
    }
    function loadRounds() { let r = gRounds(); document.getElementById('roundInput').value = r; document.getElementById('roundDisplay').innerText = r; }

    let running = false;
    function startAutoClick() {
        if(running){alert('⚠️ Already running!');return;}
        let btns = document.querySelectorAll('.offer-btn');
        if(!btns.length){alert('❌ No buttons!');return;}
        let rds = gRounds(), all = btns.length * rds;
        let st = document.getElementById('autoStatus'), sBtn = document.getElementById('autoClickBtn');
        running = true; sBtn.disabled = true; sBtn.textContent = '⏳ CLICKING...';
        let cur = 0, round = 1, idx = 0;
        st.textContent = '🔄 Round 1/'+rds+' · 0/'+all;
        let t = setInterval(() => {
            if(round>rds){clearInterval(t);st.textContent='✅ DONE! '+all+' clicks ('+btns.length+'×'+rds+')';sBtn.disabled=false;sBtn.textContent='🚀 START AUTO CLICK';running=false;return;}
            if(idx>=btns.length){round++;idx=0;if(round>rds)return;st.textContent='🔄 Round '+round+'/'+rds+' · '+cur+'/'+all;return;}
            let b=btns[idx],bid=b.id,url=b.href||b.getAttribute('href');
            if(url){let a=document.createElement('a');a.href=url;a.target='_blank';a.rel='noopener noreferrer';document.body.appendChild(a);a.click();document.body.removeChild(a);cur++;if(bid&&cMap.hasOwnProperty(bid))inc(bid);st.textContent='🔄 R'+round+'/'+rds+' · #'+cur+'/'+all+' ✅';}
            else{cur++;st.textContent='🔄 R'+round+'/'+rds+' · #'+cur+'/'+all+' ⚠️';}
            idx++;
        },2000);
    }

    for(let i=1;i<=btnsTotal;i++){let b=document.getElementById('btn_'+i);if(b)b.addEventListener('click',()=>inc('btn_'+i));}
    lCounts();loadRounds();refresh();
    console.log('✅ Medicen 58 btns | Rounds: '+gRounds());
